{
  "definitions": [
    {
      "title": "Newsletter",
      "id": "newsletter",
      "model": "newsletter",
      "plugins": {
        "da": {
          "unsafeHTML": "<div class=\"newsletter\"><div><div><h2>Subscribe and find out more about us</h2></div></div><div><div><p>email</p></div><div><p>Subscribe</p></div></div><div><div><p>Thank you for subscribing. Check your inbox soon.</p></div><div><p>Please enter a valid email address.</p></div></div><div><div><p>Please complete the verification challenge.</p></div><div><p>Something went wrong. Please try again.</p></div></div></div>",
          "fields": [
            {
              "name": "title",
              "selector": "div:nth-child(1)>div"
            },
            {
              "name": "placeholder",
              "selector": "div:nth-child(2)>div:nth-child(1)"
            },
            {
              "name": "submitLabel",
              "selector": "div:nth-child(2)>div:nth-child(2)"
            },
            {
              "name": "successMessage",
              "selector": "div:nth-child(3)>div:nth-child(1)"
            },
            {
              "name": "invalidEmailMessage",
              "selector": "div:nth-child(3)>div:nth-child(2)"
            },
            {
              "name": "verificationMessage",
              "selector": "div:nth-child(4)>div:nth-child(1)"
            },
            {
              "name": "submitErrorMessage",
              "selector": "div:nth-child(4)>div:nth-child(2)"
            }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "newsletter",
      "fields": [
        {
          "component": "richtext",
          "name": "title",
          "value": "",
          "label": "Title",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "placeholder",
          "value": "email",
          "label": "Email Label",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "submitLabel",
          "value": "Subscribe",
          "label": "Submit Label",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "successMessage",
          "value": "Thank you for subscribing. Check your inbox soon.",
          "label": "Success Message",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "invalidEmailMessage",
          "value": "Please enter a valid email address.",
          "label": "Invalid Email Message",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "verificationMessage",
          "value": "Please complete the verification challenge.",
          "label": "Verification Message",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "submitErrorMessage",
          "value": "Something went wrong. Please try again.",
          "label": "Submit Error Message",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": []
}
